[{"id":"species-Яблоня","name":"Яблоня","nameScientific":"Malus domestica","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":40,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Самое распространённое плодовое дерево в российских садах. Неприхотлива, при правильном уходе плодоносит ежегодно и обильно.","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":5}},{"id":"species-Груша","name":"Груша","nameScientific":"Pyrus communis","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":40,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Теплолюбивое плодовое дерево с сочными сладкими плодами. Современные сорта хорошо растут в средней полосе России.","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":3}},{"id":"species-Вишня","name":"Вишня","nameScientific":"Prunus cerasus","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":30,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Популярная косточковая культура. Ценится за вкусные плоды, используемые в свежем виде, для варенья, компотов и выпечки.","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":3}},{"id":"species-Слива","name":"Слива","nameScientific":"Prunus domestica","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":35,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Косточковое плодовое дерево с разнообразными сортами. Плоды используются в свежем виде, для заготовок и сушки (чернослив).","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":3}},{"id":"species-Черешня","name":"Черешня","nameScientific":"Prunus avium","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":40,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Сладкая косточковая культура с крупными плодами. В последние годы выведены зимостойкие сорта для средней полосы.","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":2}},{"id":"species-Абрикос","name":"Абрикос","nameScientific":"Prunus armeniaca","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":14,"wateringNormLiters":40,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Теплолюбивое косточковое дерево. Современные сорта адаптированы к условиям средней полосы и выдерживают морозы до -30°C.","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":2}},{"id":"species-Персик","name":"Персик","nameScientific":"Prunus persica","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":35,"sunRequirement":"FULL_SUN","soilType":"SANDY","description":"Теплолюбивая культура, успешно выращиваемая в южных регионах России. Требует защиты от курчавости листьев.","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":2}},{"id":"species-Алыча","name":"Алыча","nameScientific":"Prunus cerasifera","categoryId":"cmmsy1vho0014hof47jie9tk1","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":30,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Неприхотливая косточковая культура с обильным плодоношением. Гибридные сорта отличаются крупными плодами и высокой зимостойкостью.","category":{"id":"cmmsy1vho0014hof47jie9tk1","name":"Плодовые деревья","nameEn":"trees","icon":"🌳","order":1},"_count":{"varieties":2}},{"id":"species-Виноград столовый","name":"Виноград столовый","nameScientific":"Vitis vinifera","categoryId":"cmmsy1vhu0015hof4ewqcl86x","imageUrl":null,"wateringIntervalDays":7,"wateringNormLiters":20,"sunRequirement":"FULL_SUN","soilType":"SANDY","description":"Столовые сорта винограда предназначены для употребления в свежем виде. Требуют укрытия на зиму в большинстве регионов России.","category":{"id":"cmmsy1vhu0015hof4ewqcl86x","name":"Виноград","nameEn":"grapes","icon":"🍇","order":2},"_count":{"varieties":3}},{"id":"species-Виноград технический","name":"Виноград технический","nameScientific":"Vitis vinifera","categoryId":"cmmsy1vhu0015hof4ewqcl86x","imageUrl":null,"wateringIntervalDays":10,"wateringNormLiters":15,"sunRequirement":"FULL_SUN","soilType":"SANDY","description":"Технические сорта используются для виноделия и переработки. Многие неукрывные сорта подходят для средней полосы.","category":{"id":"cmmsy1vhu0015hof4ewqcl86x","name":"Виноград","nameEn":"grapes","icon":"🍇","order":2},"_count":{"varieties":2}},{"id":"species-Виноград кишмиш","name":"Виноград кишмиш","nameScientific":"Vitis vinifera","categoryId":"cmmsy1vhu0015hof4ewqcl86x","imageUrl":null,"wateringIntervalDays":7,"wateringNormLiters":20,"sunRequirement":"FULL_SUN","soilType":"SANDY","description":"Бессемянные сорта винограда, популярные для употребления в свежем виде и изготовления изюма.","category":{"id":"cmmsy1vhu0015hof4ewqcl86x","name":"Виноград","nameEn":"grapes","icon":"🍇","order":2},"_count":{"varieties":2}},{"id":"species-Томат","name":"Томат","nameScientific":"Solanum lycopersicum","categoryId":"cmmsy1vi00016hof4rw54hmjk","imageUrl":null,"wateringIntervalDays":3,"wateringNormLiters":5,"sunRequirement":"FULL_SUN","soilType":"LOAMY","description":"Одна из самых популярных овощных культур в России. Выращивается в теплицах и открытом грунте, имеет огромное разнообразие сортов.","category":{"id":"cmmsy1vi00016hof4rw54hmjk","name":"Овощи","nameEn":"vegetables","icon":"🥕","order":3},"_count":{"varieti